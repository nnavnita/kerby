# Copy to .env and fill in real values. .env is gitignored.

# Backend API base URL. Use your Mac's LAN IP when testing on a physical
# phone (`ipconfig getifaddr en0`), or https://kerby-api.fly.dev in prod.
KERBY_API_BASE=http://192.168.4.30:8080

# Google Maps Geocoding API key (preferred — house-level precision in AU).
# Enable the "Geocoding API" in Google Cloud Console, create an API key,
# restrict it to your app bundle IDs. ~$0/mo under $200 monthly credit.
GOOGLE_MAPS_KEY=

# LocationIQ access token (fallback if GOOGLE_MAPS_KEY is empty).
# 5k/day free, no card required. https://locationiq.com/register
LOCATIONIQ_TOKEN=
