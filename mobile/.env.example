# Copy to .env and fill in real values. .env is gitignored.

# Backend API base URL. Use your Mac's LAN IP when testing on a physical
# phone (`ipconfig getifaddr en0`), or https://kerby-api.fly.dev in prod.
KERBY_API_BASE=http://192.168.4.30:8080

# LocationIQ access token (autocomplete geocoding).
# Get one free at https://locationiq.com/register — no card required.
LOCATIONIQ_TOKEN=
