DATABASE_URL=postgres://kerby:kerby@localhost:5433/kerby
REDIS_URL=redis://localhost:6379
RUST_LOG=kerby_api=debug,kerby_worker=debug,info

# JWT signing key — generate with `openssl rand -hex 32`
JWT_SECRET=change-me-before-deploy

# City of Melbourne Open Data (Opendatasoft)
COM_API_BASE=https://data.melbourne.vic.gov.au/api/explore/v2.1/catalog/datasets
COM_API_KEY=

# Sensor poll cadence
SENSOR_POLL_INTERVAL_SECS=30

# Google Geocoding API key — used by the /geocode proxy endpoint.
# Create in Google Cloud Console, restrict to Geocoding API only.
GOOGLE_MAPS_KEY=
